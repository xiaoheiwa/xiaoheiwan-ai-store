# ===========================================
# License Authorization (Required)
# ===========================================
# 联系开发者获取授权码，只需设置这一个变量
LICENSE_KEY=your_license_key_from_developer

# ===========================================
# Database (Neon PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:password@host/database

# ===========================================
# Admin Authentication
# ===========================================
ADMIN_PASSWORD=your_admin_password_here
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ===========================================
# Telegram Notifications
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
RESEND_FROM_EMAIL=noreply@upgrade.xiaoheiwan.com

# ===========================================
# Payment - XunHuPay
# ===========================================
XUNHUPAY_API_URL=https://api.xunhupay.com/payment/do.html
XUNHUPAY_APP_ID=your_app_id
XUNHUPAY_APP_SECRET=your_app_secret

# ===========================================
# Payment - ZPayz
# ===========================================
ZPAYZ_PID=your_zpayz_pid
ZPAYZ_PKEY=your_zpayz_pkey

# ===========================================
# Payment - EPay
# ===========================================
EPAY_API_URL=https://your-epay-provider.com/mapi.php
EPAY_PID=your_epay_pid
EPAY_KEY=your_epay_key
# 紧急停用开关：仅在凭证泄露等紧急情况下设为 true，会立刻关闭支付宝/微信下单与回调发货。
# 默认 false（放行支付宝/微信）。该变量未设置时也按 false 处理。
PAYMENT_GATEWAY_EMERGENCY_HOLD=false

# ===========================================
# Crypto Payment (USDT TRC20)
# ===========================================
USDT_WALLET_ADDRESS=your_trc20_wallet_address
TRON_API_KEY=your_tron_api_key
USDT_TO_CNY_RATE=7.2

# ===========================================
# Crypto Payment - BEpusdt Gateway (Optional)
# ===========================================
BEPUSDT_BASE_URL=https://your-bepusdt-domain.com
BEPUSDT_API_TOKEN=your_bepusdt_api_token
# Default network when the frontend does not send a selection: usdt.trc20 or usdt.bep20
BEPUSDT_TRADE_TYPE=usdt.trc20
BEPUSDT_FIAT=CNY
BEPUSDT_TIMEOUT=1200

# ===========================================
# Global Store (Optional MVP)
# ===========================================
GLOBAL_STORE_ENABLED=true
GLOBAL_ORDER_EXPIRE_MINUTES=15
GLOBAL_SUPPORT_TELEGRAM=https://t.me/your_support

# Direct USDT listener config reserved for the global store.
# Keep keys server-side only; do not expose API keys in frontend code.
USDT_TRC20_ADDRESS=your_trc20_receive_address
USDT_TRC20_CONFIRMATIONS_REQUIRED=1
TRONGRID_API_KEY=your_trongrid_api_key
USDT_BEP20_ADDRESS=your_bep20_receive_address
USDT_BEP20_CONFIRMATIONS_REQUIRED=3
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSCSCAN_API_KEY=your_bscscan_api_key

# ===========================================
# Cron Jobs
# ===========================================
CRON_SECRET=your_cron_secret_here

# ===========================================
# Third-party API (Optional)
# ===========================================
CHONGZHI_API_URL=https://api.example.com
CHONGZHI_API_KEY=your_api_key
PIXEL_TASK_SIGNING_SECRET=your_pixel_task_signing_secret

# ===========================================
# Site Configuration (Optional)
# ===========================================
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
